{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "*": "ask"
    },
    "edit": {
      "*": "ask",
      "/etc/*": "deny",
      "/usr/*": "deny", 
      "/var/*": "deny",
      "~/.ssh/*": "deny",
      "*.env": "deny"
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "/etc/*": "deny"
    },
    "external_directory": "deny",
    "doom_loop": "deny"
  }
}
